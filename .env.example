# Signal 知识平台 — 环境变量配置
#
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# ─── LLM API 配置（三选一） ───

# 方式1: OpenAI (GPT-4o-mini 性价比最高)
OPENAI_API_KEY=sk-your-key-here
SIGNAL_MODEL=gpt-4o-mini

# 方式2: DeepSeek (便宜，中文质量好)
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# SIGNAL_MODEL=deepseek-chat

# 方式3: 本地 Ollama (免费，需要 GPU)
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# SIGNAL_MODEL=qwen2.5:14b

# 方式4: 腾讯混元
# OPENAI_API_KEY=your-hunyuan-key
# OPENAI_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
# SIGNAL_MODEL=hunyuan-turbo
